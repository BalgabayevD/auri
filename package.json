{
  "name": "@maguya/auri",
  "version": "0.1.0",
  "description": "Fluent chainable HTTP client based on the Fetch API",
  "author": "BalgabayevD",
  "license": "MIT",
  "type": "module",

  "main":    "./dist/index.cjs",
  "module":  "./dist/index.js",
  "types":   "./dist/index.d.ts",

  "exports": {
    ".": {
      "types":   "./dist/index.d.ts",
      "import":  "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },

  "files": ["dist"],

  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev":   "tsup src/index.ts --format esm,cjs --dts --watch",
    "prepublishOnly": "npm run build"
  },

  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}